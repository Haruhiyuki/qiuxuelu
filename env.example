# 环境变量模板：复制为 .env 后填写；.env 永不入库
DATABASE_URL=postgres://harublog:harublog@localhost:5432/harublog

# better-auth：生成方式 `openssl rand -base64 32`
BETTER_AUTH_SECRET=change-me-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Meilisearch（块级中文搜索）：web 读、worker 写；与 infra/docker-compose.yml 一致
MEILISEARCH_HOST=http://localhost:7700
MEILI_MASTER_KEY=dev-master-key

# 实时协作（Hocuspocus）：COLLAB_SECRET 由 web 签发 token、collab 验签，必须两端一致
COLLAB_SECRET=change-me-collab-shared-secret
COLLAB_PORT=3201
# 客户端连接的协作网关地址（浏览器可达）
NEXT_PUBLIC_COLLAB_URL=ws://localhost:3201
